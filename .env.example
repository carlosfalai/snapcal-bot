# Telegram
TELEGRAM_BOT_TOKEN=

# AWS — Bedrock + S3 + (optional) Transcribe
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET=snapcal-meals
BEDROCK_HAIKU_MODEL=us.anthropic.claude-haiku-4-5-20251001-v1:0

# Postgres (AWS RDS)
DATABASE_URL=postgres://user:pass@host:5432/snapcal

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID=
PUBLIC_BASE_URL=https://snapcal.example.com

# Server
PORT=3017

# Admin (optional — for ops alerts)
ADMIN_TELEGRAM_ID=
